^dash <number_small>$:
    user.astrodash_focus_tab(number_small)

^astro dash <number_small>$:
    user.astrodash_focus_tab(number_small)

^dash next$:
    user.astrodash_focus_next_tab()

^astro dash next$:
    user.astrodash_focus_next_tab()

^dash (last | previous)$:
    user.astrodash_focus_previous_tab()

^astro dash (last | previous)$:
    user.astrodash_focus_previous_tab()

^focus dash$:
    user.astrodash_focus()

^focus astro dash$:
    user.astrodash_focus()
